# =============================================================================
# Stellar Disbursement Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://sdp:sdp@localhost:5432/sdp?sslmode=disable

# ─── Backend Server ───────────────────────────────────────────────────────
PORT=8000
BASE_URL=http://localhost:8000
SDP_UI_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Authentication ───────────────────────────────────────────────────────
# EC256 private key used to sign auth tokens (generate with openssl ecparam -genkey -name prime256v1)
EC256_PRIVATE_KEY=
SEP24_JWT_SECRET=
SEP10_SIGNING_PUBLIC_KEY=
SEP10_SIGNING_PRIVATE_KEY=
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ─── Multi-tenancy ────────────────────────────────────────────────────────
SINGLE_TENANT_MODE=true

# ─── reCAPTCHA (set DISABLE_RECAPTCHA=true to skip) ──────────────────────
RECAPTCHA_SITE_KEY=
RECAPTCHA_SITE_SECRET_KEY=
DISABLE_RECAPTCHA=true

# ─── MFA ──────────────────────────────────────────────────────────────────
DISABLE_MFA=true

# ─── Circle API ───────────────────────────────────────────────────────────
CIRCLE_API_TYPE=TRANSFERS

# ─── Admin API ────────────────────────────────────────────────────────────
ADMIN_PORT=8003
ADMIN_ACCOUNT=
ADMIN_API_KEY=

# ─── Metrics ──────────────────────────────────────────────────────────────
METRICS_PORT=8002
METRICS_TYPE=PROMETHEUS

# ─── Frontend (REACT_APP_* vars are injected at build time via Vite) ────
REACT_APP_API_URL=http://localhost:8000
REACT_APP_SINGLE_TENANT_MODE=true
REACT_APP_RECAPTCHA_SITE_KEY=
REACT_APP_STELLAR_EXPERT_URL=https://stellar.expert/explorer/testnet
REACT_APP_HORIZON_URL=https://horizon-testnet.stellar.org
REACT_APP_RPC_ENABLED=false
