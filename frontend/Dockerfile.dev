# =============================================================================
# Frontend Development Image
# Pre-installs dependencies so docker compose doesn't yarn install on every start.
# Source files are bind-mounted at runtime for HMR.
# =============================================================================
FROM node:22-alpine

# git is required by the "yarn git-info" script (called by yarn start)
RUN apk add --no-cache git

WORKDIR /app

# Install dependencies (layer caching)
COPY package.json yarn.lock ./
RUN yarn install --frozen-lockfile

# Expose Vite dev server port
EXPOSE 3000

CMD ["yarn", "start"]
